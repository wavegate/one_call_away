# xAI Grok Voice (required for voice agent)
XAI_API_KEY=

# Twilio (required for live demo calls)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
SUPPORTER_PHONE=

# Your phone number — called during warm transfer when Circle answers
MEMBER_PHONE=

# Public URL for Twilio webhooks (use ngrok for local dev)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: xAI Grok for text-only escalation fallback (not needed with Grok Voice)
# XAI_API_KEY is set above for voice

# Demo member name
DEMO_MEMBER_NAME=Frank
