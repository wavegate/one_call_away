# xAI Grok Voice (required for voice agent)
XAI_API_KEY=

# Twilio (required for live demo calls)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
SUPPORTER_PHONE=

# Your phone number — called during warm transfer when Circle answers
MEMBER_PHONE=

# Public URL for Twilio webhooks (use ngrok for local dev only — do NOT set this to ngrok on Vercel)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Turso database credentials (NOT the Turso platform/API token from Account Settings)
# URL from: turso db show <name> --url  (use the https:// value)
# DB token from: turso db tokens create <name>  (or Database → Create Token in dashboard)
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Optional: xAI Grok for text-only escalation fallback (not needed with Grok Voice)
# XAI_API_KEY is set above for voice

# Demo member name
DEMO_MEMBER_NAME=Frank
